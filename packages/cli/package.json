{
  "name": "pocketpatch",
  "version": "0.1.1",
  "description": "Mobile-friendly local diff review for agent-generated code changes.",
  "license": "MIT",
  "author": "Kaden Cartwright <cartwrightkaden@gmail.com>",
  "homepage": "https://github.com/kadencartwright/pocketpatch#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/kadencartwright/pocketpatch.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/kadencartwright/pocketpatch/issues"
  },
  "keywords": [
    "agent",
    "code-review",
    "diff",
    "mobile",
    "tailscale"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "pocketpatch": "./dist/bin.js"
  },
  "files": [
    "dist/bin.js",
    "dist/web",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && pnpm run build:package",
    "build:bundle": "tsup src/bin.ts --format esm --platform node --target node20 --out-dir dist --external @effect/cli --external @effect/experimental --external @effect/platform --external @effect/platform-node --external @effect/sql --external @effect/sql-sqlite-node --external better-sqlite3 --external effect && chmod +x dist/bin.js",
    "build:package": "rm -rf dist && pnpm run build:bundle && pnpm --dir ../../apps/web run build && cp -R ../../apps/web/dist dist/web",
    "dev": "tsx src/bin.ts daemon start",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "pnpm run build",
    "publish:npm": "npm publish",
    "publish:npm:dry-run": "npm publish --dry-run",
    "test": "vitest run --root ../.. packages/cli/test",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-node": "^0.52.0",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@pocketpatch/config": "workspace:*",
    "@pocketpatch/daemon": "workspace:*",
    "@pocketpatch/network": "workspace:*",
    "@pocketpatch/storage": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
