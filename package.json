{
  "name": "pocketpatch",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "lefthook install",
    "test": "bun test ./packages/*/test",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.2",
    "lefthook": "^2.1.9",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3"
  }
}
